{
  "manifest_version": 3,
  "name": "Repo Learner",
  "version": "0.1.0",
  "description": "帮你逐层读懂 GitHub 开源项目",

  "permissions": ["storage", "activeTab", "tabs"],

  "host_permissions": [
    "https://api.github.com/*",
    "https://api.deepseek.com/*",
    "https://github.com/*"
  ],

  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://github.com/*/*"],
      "js": ["src/content.tsx"]
    }
  ],

  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": false
  },

  "web_accessible_resources": [
    {
      "resources": ["src/agent/prompt.md"],
      "matches": ["https://github.com/*"]
    }
  ]
}
